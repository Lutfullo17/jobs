  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            ""
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"API is running\", function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().message).to.eql(\"Jobify Auth API is running\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Register",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.environment.get(\"email\") || pm.environment.get(\"email\") === \"candidate@example.com\") {",
              "  pm.environment.set(\"email\", `candidate_${Date.now()}@example.com`);",
              "}",
              "if (!pm.environment.get(\"password\")) {",
              "  pm.environment.set(\"password\", \"Password123!\");",
              "}",
              "if (!pm.environment.get(\"role\")) {",
              "  pm.environment.set(\"role\", \"candidate\");",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Register status is 201\", function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Register response has user and message\", function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property(\"user\");",
              "  pm.expect(json.user.email).to.eql(pm.environment.get(\"email\"));",
              "  pm.expect(json.user.is_verified).to.eql(false);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"confirm_password\": \"{{password}}\",\n  \"role\": \"{{role}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/register/",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "register",
            ""
          ]
        }
      },
      "response": []
    },
