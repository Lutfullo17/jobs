# --- Docker Compose (app/celery konteynerlari) ---
# docker-compose.yml ichidagi DATABASE_URL va REDIS_URL ustun keladi.
# Quyidagi qiymatlar asosan hujjat uchun; nusxa: copy .env.example .env

DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/jobify
REDIS_URL=redis://redis:6379/0

# --- Lokal uvicorn (Docker faqat db+redis, API run-with-docker.bat) ---
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/jobify
# REDIS_URL=redis://127.0.0.1:6500/0

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# Haqiqiy parol qo'ymang — faqat placeholder. Production: .env ni git'ga commit qilmang.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password-here
EMAIL_FROM=noreply@example.com
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=true
RATE_LIMIT_LOGIN_LIMIT=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_RESEND_LIMIT=1
RATE_LIMIT_RESEND_WINDOW_SECONDS=60
RATE_LIMIT_FORGOT_LIMIT=3
RATE_LIMIT_FORGOT_WINDOW_SECONDS=300
